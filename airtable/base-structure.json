{
  "baseName": "Referee Scheduling",
  "description": "Complete database structure for referee scheduling system",
  "tables": [
    {
      "name": "Referees",
      "description": "Master list of all referees",
      "primaryField": "Name",
      "fields": [
        {
          "name": "Referee ID",
          "type": "autonumber",
          "description": "Unique identifier for each referee"
        },
        {
          "name": "Name",
          "type": "singleLineText",
          "description": "Full name of referee",
          "required": true
        },
        {
          "name": "Email",
          "type": "email",
          "description": "Contact email",
          "required": true
        },
        {
          "name": "Phone",
          "type": "phoneNumber",
          "description": "Contact phone number"
        },
        {
          "name": "Certification Level",
          "type": "singleSelect",
          "options": ["Grade 8", "Grade 7", "Grade 6", "Grade 5", "Regional", "National"],
          "description": "Referee certification level"
        },
        {
          "name": "Travel Distance",
          "type": "number",
          "description": "Maximum miles willing to travel",
          "format": "integer"
        },
        {
          "name": "Clubs",
          "type": "multipleRecordLinks",
          "linkedTable": "Clubs",
          "description": "Clubs the referee works for"
        },
        {
          "name": "Notes",
          "type": "multilineText",
          "description": "Additional notes about referee"
        },
        {
          "name": "Status",
          "type": "singleSelect",
          "options": ["Active", "Inactive", "On Leave"],
          "description": "Current status"
        },
        {
          "name": "Availability Submissions",
          "type": "multipleRecordLinks",
          "linkedTable": "Availability",
          "description": "Link to availability submissions"
        },
        {
          "name": "Games - Center",
          "type": "multipleRecordLinks",
          "linkedTable": "Games",
          "description": "Games assigned as center referee"
        },
        {
          "name": "Games - AR1",
          "type": "multipleRecordLinks",
          "linkedTable": "Games",
          "description": "Games assigned as AR1"
        },
        {
          "name": "Games - AR2",
          "type": "multipleRecordLinks",
          "linkedTable": "Games",
          "description": "Games assigned as AR2"
        }
      ]
    },
    {
      "name": "Clubs",
      "description": "Soccer clubs and organizations",
      "primaryField": "Club Name",
      "fields": [
        {
          "name": "Club ID",
          "type": "autonumber",
          "description": "Unique identifier for each club"
        },
        {
          "name": "Club Name",
          "type": "singleLineText",
          "description": "Name of the club",
          "required": true
        },
        {
          "name": "Assignor",
          "type": "singleLineText",
          "description": "Name of person assigning games"
        },
        {
          "name": "Assignor Email",
          "type": "email",
          "description": "Assignor contact email"
        },
        {
          "name": "Assignor Phone",
          "type": "phoneNumber",
          "description": "Assignor contact phone"
        },
        {
          "name": "Region",
          "type": "singleSelect",
          "options": ["North", "South", "East", "West", "Central"],
          "description": "Geographic region"
        },
        {
          "name": "Referees",
          "type": "multipleRecordLinks",
          "linkedTable": "Referees",
          "description": "Referees working for this club"
        },
        {
          "name": "Fields",
          "type": "multipleRecordLinks",
          "linkedTable": "Fields",
          "description": "Fields owned/managed by this club"
        },
        {
          "name": "Games",
          "type": "multipleRecordLinks",
          "linkedTable": "Games",
          "description": "Games hosted by this club"
        },
        {
          "name": "Notes",
          "type": "multilineText",
          "description": "Additional club information"
        }
      ]
    },
    {
      "name": "Fields",
      "description": "Game locations and facilities",
      "primaryField": "Field Name",
      "fields": [
        {
          "name": "Field ID",
          "type": "autonumber",
          "description": "Unique identifier for each field"
        },
        {
          "name": "Field Name",
          "type": "singleLineText",
          "description": "Name of the field (e.g., 'Rye Field 1')",
          "required": true
        },
        {
          "name": "Address",
          "type": "singleLineText",
          "description": "Street address"
        },
        {
          "name": "City",
          "type": "singleLineText",
          "description": "City"
        },
        {
          "name": "State",
          "type": "singleLineText",
          "description": "State or province"
        },
        {
          "name": "Zip Code",
          "type": "singleLineText",
          "description": "Zip or postal code"
        },
        {
          "name": "Club",
          "type": "multipleRecordLinks",
          "linkedTable": "Clubs",
          "description": "Club that manages this field",
          "allowMultiple": false
        },
        {
          "name": "GPS Coordinates",
          "type": "singleLineText",
          "description": "Latitude, longitude for mapping"
        },
        {
          "name": "Parking Notes",
          "type": "multilineText",
          "description": "Parking information"
        },
        {
          "name": "Field Notes",
          "type": "multilineText",
          "description": "Surface type, size, amenities"
        },
        {
          "name": "Games",
          "type": "multipleRecordLinks",
          "linkedTable": "Games",
          "description": "Games scheduled at this field"
        }
      ]
    },
    {
      "name": "Games",
      "description": "Scheduled games and referee assignments",
      "primaryField": "Game ID",
      "fields": [
        {
          "name": "Game ID",
          "type": "autonumber",
          "description": "Unique identifier for each game"
        },
        {
          "name": "Date",
          "type": "date",
          "description": "Game date",
          "required": true,
          "includeTime": false
        },
        {
          "name": "Time",
          "type": "singleLineText",
          "description": "Game time (e.g., '10:00 AM')",
          "required": true
        },
        {
          "name": "Field",
          "type": "multipleRecordLinks",
          "linkedTable": "Fields",
          "description": "Game location",
          "allowMultiple": false
        },
        {
          "name": "Home Team",
          "type": "singleLineText",
          "description": "Home team name"
        },
        {
          "name": "Away Team",
          "type": "singleLineText",
          "description": "Away team name"
        },
        {
          "name": "Age Group",
          "type": "singleSelect",
          "options": ["U8", "U9", "U10", "U11", "U12", "U13", "U14", "U15", "U16", "U17", "U18", "U19"],
          "description": "Age group/division"
        },
        {
          "name": "Division",
          "type": "singleSelect",
          "options": ["Recreational", "Travel", "Premier", "Elite"],
          "description": "Competition level"
        },
        {
          "name": "Center Ref",
          "type": "multipleRecordLinks",
          "linkedTable": "Referees",
          "description": "Assigned center referee",
          "allowMultiple": false
        },
        {
          "name": "AR1",
          "type": "multipleRecordLinks",
          "linkedTable": "Referees",
          "description": "Assigned assistant referee 1",
          "allowMultiple": false
        },
        {
          "name": "AR2",
          "type": "multipleRecordLinks",
          "linkedTable": "Referees",
          "description": "Assigned assistant referee 2",
          "allowMultiple": false
        },
        {
          "name": "Club",
          "type": "multipleRecordLinks",
          "linkedTable": "Clubs",
          "description": "Hosting club",
          "allowMultiple": false
        },
        {
          "name": "Game Status",
          "type": "singleSelect",
          "options": ["Scheduled", "Confirmed", "Completed", "Cancelled"],
          "description": "Current game status"
        },
        {
          "name": "Payment Status",
          "type": "singleSelect",
          "options": ["Pending", "Paid", "Invoiced"],
          "description": "Payment tracking"
        },
        {
          "name": "Notes",
          "type": "multilineText",
          "description": "Game notes or special instructions"
        }
      ],
      "views": [
        {
          "name": "All Games",
          "type": "grid",
          "sort": [{"field": "Date", "direction": "asc"}]
        },
        {
          "name": "Unassigned Games",
          "type": "grid",
          "filter": "AND({Center Ref} = BLANK())",
          "sort": [{"field": "Date", "direction": "asc"}]
        },
        {
          "name": "This Weekend",
          "type": "grid",
          "filter": "Date is within next 7 days",
          "sort": [{"field": "Date", "direction": "asc"}]
        }
      ]
    },
    {
      "name": "Availability",
      "description": "Referee availability submissions from web form",
      "primaryField": "Submission ID",
      "fields": [
        {
          "name": "Submission ID",
          "type": "autonumber",
          "description": "Unique identifier for each submission"
        },
        {
          "name": "Referee",
          "type": "multipleRecordLinks",
          "linkedTable": "Referees",
          "description": "Link to referee record (match by email)",
          "allowMultiple": false
        },
        {
          "name": "Referee Name",
          "type": "singleLineText",
          "description": "Name from form submission",
          "required": true
        },
        {
          "name": "Referee Email",
          "type": "email",
          "description": "Email from form submission",
          "required": true
        },
        {
          "name": "Referee Phone",
          "type": "phoneNumber",
          "description": "Phone from form submission"
        },
        {
          "name": "Certification Level",
          "type": "singleSelect",
          "options": ["Grade 8", "Grade 7", "Grade 6", "Grade 5", "Regional", "National"],
          "description": "Referee certification level"
        },
        {
          "name": "Date",
          "type": "date",
          "description": "Date they're available",
          "required": true,
          "includeTime": false
        },
        {
          "name": "Start Time",
          "type": "singleLineText",
          "description": "Availability start time"
        },
        {
          "name": "End Time",
          "type": "singleLineText",
          "description": "Availability end time"
        },
        {
          "name": "Preferred Locations",
          "type": "multipleSelects",
          "options": ["Rye", "Harrison", "Mamaroneck", "Larchmont", "New Rochelle", "Pelham", "White Plains", "Scarsdale", "Any Location"],
          "description": "Locations willing to travel to"
        },
        {
          "name": "Positions Willing",
          "type": "multipleSelects",
          "options": ["Center Referee", "Assistant Referee 1", "Assistant Referee 2", "4th Official"],
          "description": "Positions willing to work"
        },
        {
          "name": "Age Groups Preferred",
          "type": "multipleSelects",
          "options": ["U8-U10", "U11-U12", "U13-U14", "U15-U16", "U17-U19", "Adult", "Any Age Group"],
          "description": "Preferred age groups"
        },
        {
          "name": "Travel Distance",
          "type": "number",
          "description": "Maximum miles willing to travel",
          "format": "integer"
        },
        {
          "name": "Notes",
          "type": "multilineText",
          "description": "Additional notes from referee"
        },
        {
          "name": "Status",
          "type": "singleSelect",
          "options": ["New", "Reviewed", "Assigned", "Archived"],
          "description": "Submission status"
        },
        {
          "name": "Submitted At",
          "type": "createdTime",
          "description": "When the form was submitted"
        }
      ],
      "views": [
        {
          "name": "All Submissions",
          "type": "grid",
          "sort": [{"field": "Submitted At", "direction": "desc"}]
        },
        {
          "name": "New Submissions",
          "type": "grid",
          "filter": "{Status} = 'New'",
          "sort": [{"field": "Submitted At", "direction": "desc"}]
        },
        {
          "name": "By Date",
          "type": "grid",
          "group": [{"field": "Date", "direction": "asc"}],
          "sort": [{"field": "Date", "direction": "asc"}]
        }
      ]
    }
  ],
  "relationships": [
    {
      "description": "Referees can work for multiple Clubs",
      "table1": "Referees",
      "field1": "Clubs",
      "table2": "Clubs",
      "field2": "Referees",
      "type": "many-to-many"
    },
    {
      "description": "Clubs manage multiple Fields",
      "table1": "Clubs",
      "field1": "Fields",
      "table2": "Fields",
      "field2": "Club",
      "type": "one-to-many"
    },
    {
      "description": "Fields host multiple Games",
      "table1": "Fields",
      "field1": "Games",
      "table2": "Games",
      "field2": "Field",
      "type": "one-to-many"
    },
    {
      "description": "Clubs host multiple Games",
      "table1": "Clubs",
      "field1": "Games",
      "table2": "Games",
      "field2": "Club",
      "type": "one-to-many"
    },
    {
      "description": "Referees submit multiple Availability records",
      "table1": "Referees",
      "field1": "Availability Submissions",
      "table2": "Availability",
      "field2": "Referee",
      "type": "one-to-many"
    },
    {
      "description": "Games are assigned to Referees (Center, AR1, AR2)",
      "table1": "Games",
      "fields": ["Center Ref", "AR1", "AR2"],
      "table2": "Referees",
      "fields": ["Games - Center", "Games - AR1", "Games - AR2"],
      "type": "many-to-one (multiple fields)"
    }
  ]
}
